<% layout("/layouts/boilerplate") %>
<body>
  <style>
    #filters {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: nowrap;
      overflow: hidden;
    }
    .filters-icons {
      display: flex;
      align-items: center;
      flex-wrap: nowrap;
      overflow: hidden;
      flex: 1;
    }
    .filter {
      text-align: center;
      margin-right: 2rem;
      margin-top: 1rem;
      opacity: 0.7;
      flex-shrink: 0;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
    }
    .filter:hover { opacity: 1; }
    .filter.active {
      opacity: 1;
      border-bottom: 2px solid #222;
      padding-bottom: 4px;
    }
    .filter p { font-size: 0.8rem; margin-bottom: 0; }
    .tax-info { display: none; }
    .tax-toggle {
      border: 1px solid black;
      border-radius: 1rem;
      height: 3.25rem;
      padding: 0.5rem 1rem;
      display: flex;
      align-items: center;
      flex-shrink: 0;
      margin-top: 1rem;
      white-space: nowrap;
    }
    #filter-dropdown { display: none; }

    @media (min-width: 992px) {
      .filter { display: block; }
      #filter-dropdown { display: none; }
    }
    @media (min-width: 768px) and (max-width: 991px) {
      .filter { display: none; }
      .filter:nth-child(-n+5) { display: block; }
      #filter-dropdown { display: none; }
    }
    @media (max-width: 767px) {
      .filter { display: none; }
      #filter-dropdown { display: block; margin-top: 1rem; margin-right: 1rem; }
    }
  </style>

  <div id="filters" class="mt-3">
    <!-- Dropdown (small screens) -->
    <select id="filter-dropdown" class="form-select w-auto"
      onchange="window.location.href='/listings?category=' + this.value">
      <option value="">All Filters</option>
      <option value="trending"   <%= activeCategory === 'trending'   ? 'selected' : '' %>>Trending</option>
      <option value="rooms"      <%= activeCategory === 'rooms'      ? 'selected' : '' %>>Rooms</option>
      <option value="cities"     <%= activeCategory === 'cities'     ? 'selected' : '' %>>Cities</option>
      <option value="mountains"  <%= activeCategory === 'mountains'  ? 'selected' : '' %>>Mountains</option>
      <option value="castles"    <%= activeCategory === 'castles'    ? 'selected' : '' %>>Castles</option>
      <option value="pools"      <%= activeCategory === 'pools'      ? 'selected' : '' %>>Pools</option>
      <option value="camping"    <%= activeCategory === 'camping'    ? 'selected' : '' %>>Camping</option>
      <option value="farms"      <%= activeCategory === 'farms'      ? 'selected' : '' %>>Farms</option>
      <option value="arctic"     <%= activeCategory === 'arctic'     ? 'selected' : '' %>>Arctic</option>
      <option value="domes"      <%= activeCategory === 'domes'      ? 'selected' : '' %>>Domes</option>
      <option value="houseboats" <%= activeCategory === 'houseboats' ? 'selected' : '' %>>Houseboats</option>
    </select>

    <!-- Icon filters -->
    <div class="filters-icons">
      <a href="/listings?category=trending"   class="filter <%= activeCategory === 'trending'   ? 'active' : '' %>"><div><i class="fa-solid fa-fire"></i></div><p>Trending</p></a>
      <a href="/listings?category=rooms"      class="filter <%= activeCategory === 'rooms'      ? 'active' : '' %>"><div><i class="fa-solid fa-bed"></i></div><p>Rooms</p></a>
      <a href="/listings?category=cities"     class="filter <%= activeCategory === 'cities'     ? 'active' : '' %>"><div><i class="fa-solid fa-mountain-city"></i></div><p>Cities</p></a>
      <a href="/listings?category=mountains"  class="filter <%= activeCategory === 'mountains'  ? 'active' : '' %>"><div><i class="fa-solid fa-mountain"></i></div><p>Mountains</p></a>
      <a href="/listings?category=castles"    class="filter <%= activeCategory === 'castles'    ? 'active' : '' %>"><div><i class="fa-brands fa-fort-awesome"></i></div><p>Castles</p></a>
      <a href="/listings?category=pools"      class="filter <%= activeCategory === 'pools'      ? 'active' : '' %>"><div><i class="fa-solid fa-person-swimming"></i></div><p>Pools</p></a>
      <a href="/listings?category=camping"    class="filter <%= activeCategory === 'camping'    ? 'active' : '' %>"><div><i class="fa-solid fa-tent"></i></div><p>Camping</p></a>
      <a href="/listings?category=farms"      class="filter <%= activeCategory === 'farms'      ? 'active' : '' %>"><div><i class="fa-solid fa-seedling"></i></div><p>Farms</p></a>
      <a href="/listings?category=arctic"     class="filter <%= activeCategory === 'arctic'     ? 'active' : '' %>"><div><i class="fa-solid fa-snowflake"></i></div><p>Arctic</p></a>
      <a href="/listings?category=domes"      class="filter <%= activeCategory === 'domes'      ? 'active' : '' %>"><div><i class="fa-solid fa-igloo"></i></div><p>Domes</p></a>
      <a href="/listings?category=houseboats" class="filter <%= activeCategory === 'houseboats' ? 'active' : '' %>"><div><i class="fa-solid fa-ship"></i></div><p>Houseboats</p></a>
    </div>

    <!-- Tax toggle -->
    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault">
        <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
      </div>
    </div>
  </div>

  <!-- Empty state -->
  <% if(allListings.length === 0) { %>
    <div class="text-center mt-5">
      <i class="fa-solid fa-magnifying-glass fa-2x mb-3" style="color:#ccc;"></i>
      <h4>No listings found</h4>
      <p class="text-muted">
        <% if(searchQuery) { %>
          No results for "<strong><%= searchQuery %></strong>".
        <% } else { %>
          No listings in this category yet.
        <% } %>
        &nbsp;<a href="/listings">Clear filters</a>
      </p>
    </div>
  <% } else { %>
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings){ %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>
              &#8377; <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "Price not available" %> /night
              <i class="tax-info">&nbsp; + 18% GST</i>
            </p>
          </div>
        </div>
      </a>
    <% } %>
  </div>
  <% } %>
</body>

<script>
  let taxSwitch = document.getElementById("flexSwitchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for(info of taxInfo){
      if(info.style.display != "inline"){
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  });
</script>